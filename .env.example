# Data Driven Decision Dashboard local defaults

# Local repository scan root. The collector scans immediate child folders only.
DASHBOARD_REPO_ROOT=/Users/manczg/Documents/work/development

# Local SQLite-compatible database path.
DATABASE_URL=file:./data/local.db

# Runtime repository selection and team mapping config.
TEAM_MAPPING_PATH=./config/team-mapping.json

# GitHub REST API.
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_TOKEN=

# Parsed `origin` owner must match this GitHub org for PR sync and metrics (case-insensitive). Others are skipped like excluded repos.
GITHUB_SYNC_OWNER=gde-mit

# Dashboard range and initial sync behavior.
DASHBOARD_DEFAULT_RANGE_WEEKS=8
DASHBOARD_INITIAL_SYNC_FROM=2026-01-01

# Keep refresh gentle for large repo sets and GitHub rate limits.
GITHUB_SYNC_CONCURRENCY=2

