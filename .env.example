# Data Driven Decision Dashboard local defaults
#
# Two supported workflows:
#
#  1. Host-side (default): `npm run dev` runs on your machine, Postgres in
#     Docker. Keep DASHBOARD_REPO_ROOT, DATABASE_URL, TEST_DATABASE_URL below.
#
#  2. Full Docker (optional): Vite dev server + Postgres both in containers.
#     Copy docker-compose.override.yml.example → docker-compose.override.yml
#     and edit the bind-mount path. In that mode, REMOVE (or comment out)
#     DASHBOARD_REPO_ROOT, DATABASE_URL, and TEST_DATABASE_URL from this
#     file — compose injects container-correct values, and scripts/local-env.ts
#     would otherwise overwrite them with the host-side values below.

# Local repository scan root. The collector scans immediate child folders only.
DASHBOARD_REPO_ROOT=/Users/manczg/Documents/work/development

# PostgreSQL connection URI (must include a host, e.g. 127.0.0.1 — not postgresql:///dbname).
# If you use the repo Docker Compose database (recommended): copy this line as-is after `npm run db:up`.
# If you use your own Postgres: replace USER, PASSWORD, port, and database name.
# Percent-encode reserved characters in USER or PASSWORD (@ : # / etc.), e.g. @ → %40.
DATABASE_URL=postgresql://dddd:dddd_local_dev@127.0.0.1:54332/dddd_dev

# Disposable database for fixture-backed Playwright e2e tests.
TEST_DATABASE_URL=postgresql://dddd:dddd_local_dev@127.0.0.1:54332/dddd_test

# Runtime repository selection and team mapping config.
TEAM_MAPPING_PATH=./config/team-mapping.json

# GitHub REST API.
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_TOKEN=

# Parsed `origin` owner must match this GitHub org for PR sync and metrics (case-insensitive). Others are skipped like excluded repos.
GITHUB_SYNC_OWNER=gde-mit

# Dashboard range and initial sync behavior.
DASHBOARD_DEFAULT_RANGE_WEEKS=8
DASHBOARD_INITIAL_SYNC_FROM=2026-01-01

# Keep refresh gentle for large repo sets and GitHub rate limits.
GITHUB_SYNC_CONCURRENCY=2

# Playwright e2e only: skip GitHub sync and insert a finished sync run (see scripts/e2e-web-server.sh).
# DASHBOARD_E2E_REFRESH_STUB=1
