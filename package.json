{
  "name": "dddd",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:live": "playwright test --config playwright.live.config.ts",
    "verify:phase01": "npm run lint && npm run typecheck && npm run build && npm run test -- --coverage && npm run test:e2e",
    "verify:phase02": "npm run lint && npm run typecheck && vitest run --coverage --config vitest.config.phase02.ts && playwright test --grep @phase02",
    "stack:up": "bash scripts/dev-up.sh",
    "stack:down": "bash scripts/dev-down.sh",
    "db:up": "docker compose up -d --wait",
    "db:down": "docker compose down",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "collector:refresh": "tsx scripts/refresh.ts",
    "db:import-github": "tsx scripts/import-github-repos.ts",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-start": "^1.167.65",
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@playwright/test": "^1.52.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^3.2.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.26.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "tsx": "^4.19.4",
    "vite": "^8.0.12",
    "vitest": "^3.1.2"
  }
}
